<%- include("includes/header") %>

<h3 class="mb-4">Possible Conditions</h3>

<% if (typeof message !== 'undefined' && message) { %>
    <div class="alert alert-info" role="alert">
        <%= message %>
    </div>
<% } %>

<% if (cards && cards.length > 0) { %>
    <div class="row">
        <% cards.forEach(card => { %>
            <div class="col-md-4 mb-4">
                <div class="card shadow h-100">
                    <div class="card-body">
                        <h5 class="card-title text-primary"><%= card.disease %></h5>
                        <p class="card-text">Confidence: <strong><%= card.confidence %>%</strong></p>
                        <p><%= card.summary %></p>
                        <span class="badge bg-warning text-dark">Risk: <%= card.riskLevel.toUpperCase() %></span>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
<% } else { %>
    <div class="alert alert-warning" role="alert">
        No matching conditions found for your symptoms. Please try again with different symptoms.
    </div>
<% } %>

<a href="/" class="btn btn-secondary mt-3">Back</a>

<%- include("includes/footer") %>